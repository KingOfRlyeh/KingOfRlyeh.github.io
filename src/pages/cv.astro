---
import BaseLayout from '../layouts/BaseLayout.astro';
import CourseworkColumn from '../components/CourseworkColumn.jsx';
import ExtracurricularColumn from '../components/ExtracurricularColumn.jsx';
import SkillsBox from '../components/SkillsBox.jsx';
import InterestsBox from '../components/InterestsBox.jsx';
---

<BaseLayout title="Curriculum Vitae">
  <main class="min-h-screen bg-white text-[#111] px-6 py-12 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 flex flex-wrap items-center justify-between gap-4">
        <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight">Curriculum Vitae</h1>
        <a href="/" class="border border-[#111] px-4 py-2 text-sm uppercase tracking-[0.2em] transition hover:bg-[#111] hover:text-white">Home</a>
      </div>

      <div class="grid gap-8 md:grid-cols-2">
        <SkillsBox />
        <InterestsBox />
      </div>

      <div class="my-10 h-px bg-[#ddd]" aria-hidden="true"></div>

      <div class="grid gap-8 md:grid-cols-2">
        <CourseworkColumn client:load />
        <ExtracurricularColumn client:load />
      </div>
    </div>
  </main>
</BaseLayout>
