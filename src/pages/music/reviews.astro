---
import { getCollection, type CollectionEntry } from 'astro:content';
import ReviewCard from '../../components/ReviewCard.jsx';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allReviews = await getCollection('reviews');
const reviews = allReviews.sort((a: CollectionEntry<'reviews'>, b: CollectionEntry<'reviews'>) =>
  (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0)
);
---

<BaseLayout title="Reviews">
<main class="bg-[#f4e9dc] text-[#222] font-mono px-6 py-12 min-h-screen relative">
  <h1 class="text-4xl md:text-5xl text-center font-bold text-[#542437] mb-12">Reviews</h1>
  <div class="max-w-4xl mx-auto grid gap-8 grid-cols-1 sm:grid-cols-2">
    {reviews.map((rev: CollectionEntry<'reviews'>) => (
      <a href={`/music/reviews/${rev.id.replace(/\.md$/, '')}`} class="no-underline">
        <ReviewCard
          title={rev.data.title}
          desc={rev.data.desc}
          img={rev.data.image}
          type={rev.data.type}
        />
      </a>
    ))}
  </div>
</main>
</BaseLayout>
