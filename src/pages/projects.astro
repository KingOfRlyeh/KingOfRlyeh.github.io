---
import ProjectGallery from '../components/ProjectGallery.jsx';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Projects">
  <main class="min-h-screen bg-white text-[#111] px-6 py-12 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-5xl">
      <div class="mb-10 flex flex-wrap items-center justify-between gap-4">
        <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight">Projects</h1>
        <a href="/" class="border border-[#111] px-4 py-2 text-sm uppercase tracking-[0.2em] transition hover:bg-[#111] hover:text-white">Home</a>
      </div>

      <div class="mx-auto max-w-4xl">
        <ProjectGallery client:load />
      </div>
    </div>
  </main>
</BaseLayout>
