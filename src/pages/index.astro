---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="JW Bollenbacher">
  <main class="min-h-screen bg-white text-[#111] flex items-center justify-center px-6 py-16">
    <div class="max-w-xl text-center">
      <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight mb-6">JW Bollenbacher</h1>
      <p class="text-base sm:text-lg leading-8 text-[#444] mb-8">
        A simple landing page with links to my work and background.
      </p>
      <nav class="flex flex-wrap justify-center gap-4 text-sm uppercase tracking-[0.2em]">
        <a href="/cv" class="border border-[#111] px-4 py-2 hover:bg-[#111] hover:text-white transition">CV</a>
        <a href="/projects" class="border border-[#111] px-4 py-2 hover:bg-[#111] hover:text-white transition">Projects</a>
      </nav>
    </div>
  </main>
</BaseLayout>
