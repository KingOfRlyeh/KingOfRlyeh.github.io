---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono&display=swap" rel="stylesheet">
    <link rel="icon" href="/myicon.png" type="image/png" />
    <title>JW Bollenbacher</title>
  </head>
  <body>
    <main>
      <h1>JW Bollenbacher</h1>
      <p class="message">
        <!-- Leave your message to visitors here -->
        This site is no longer active. You can find me at [https://king-of-rlyeh.neocities.org/]. Join me in the (web revival)[https://web-revival.neocities.org/]
      </p>
    </main>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'IBM Plex Mono', monospace;
        background: #fff;
        color: #111;
      }
      main {
        text-align: center;
        padding: 2rem;
      }
      h1 {
        font-size: 2rem;
        margin-bottom: 1rem;
      }
      .message {
        font-size: 1rem;
        color: #444;
      }
    </style>
  </body>
</html>
