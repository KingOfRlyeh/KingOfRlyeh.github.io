---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="JW Bollenbacher">
  <main class="min-h-screen bg-white text-[#111] flex items-center justify-center px-6 py-16">
    <div class="max-w-2xl text-center">
      <p class="text-[0.7rem] uppercase tracking-[0.35em] text-[#666] mb-4">Jack Bollenbacher</p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight mb-5">Quiet work. Clear presence.</h1>
      <p class="text-base sm:text-lg leading-8 text-[#444]">
        This site is currently kept as a simple, minimal landing page. The focus is on clarity, restraint, and a clean presentation.
      </p>
    </div>
  </main>
</BaseLayout>
